@using ZamAiMart.Client.Models
@inject NavigationManager Nav

<div class="group bg-white dark:bg-gray-800 rounded-2xl border border-gray-200 dark:border-gray-700 p-5 hover:shadow-xl hover:shadow-violet-100 dark:hover:shadow-violet-900/20 hover:border-violet-200 dark:hover:border-violet-700 transition-all duration-300 cursor-pointer flex flex-col"
     @onclick="OpenDetails">
    <div class="flex items-start justify-between mb-3">
        <div class="flex items-center space-x-3">
            <div class="w-12 h-12 rounded-xl overflow-hidden bg-white dark:bg-gray-900 ring-1 ring-gray-200 dark:ring-gray-700 flex items-center justify-center shrink-0 p-2">
                @if (!string.IsNullOrWhiteSpace(_logoUrl))
                {
                    <img src="@_logoUrl"
                         alt="@Tool.Name logo"
                         class="w-full h-full object-contain"
                         @onerror="HandleLogoError" />
                }
            </div>
            <div class="min-w-0">
                <h3 class="font-bold text-gray-900 dark:text-white text-sm truncate group-hover:text-violet-600 dark:group-hover:text-violet-400 transition-colors">@Tool.Name</h3>
                <span class="text-xs text-gray-500 dark:text-gray-400 truncate block">@Tool.Category</span>
            </div>
        </div>
    </div>
    <p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed line-clamp-2 flex-1 mb-4">@Tool.Description</p>
    <div class="flex items-center justify-between mt-auto pt-3 border-t border-gray-100 dark:border-gray-700">
        <span class="@(Tool.IsFree ? "bg-emerald-100 dark:bg-emerald-900/30 text-emerald-700 dark:text-emerald-400" : "bg-violet-100 dark:bg-violet-900/30 text-violet-700 dark:text-violet-400") text-xs font-bold px-2.5 py-1 rounded-lg">
            @Tool.FormattedPrice
        </span>
        <a href="@Tool.WebsiteURL" target="_blank" rel="noopener noreferrer" @onclick:stopPropagation="true"
           class="text-xs bg-violet-600 hover:bg-violet-700 text-white px-3 py-1.5 rounded-lg font-medium transition-colors flex items-center gap-1">
            Visit Website
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14" />
            </svg>
        </a>
    </div>
    @if (Tool.HasMobileApps)
    {
        <div class="mt-3 flex flex-wrap gap-2">
            @if (Tool.HasPlayStoreUrl)
            {
                <a href="@Tool.PlayStoreUrl" target="_blank" rel="noopener noreferrer" @onclick:stopPropagation="true"
                   class="inline-flex items-center rounded-xl border border-emerald-200 bg-emerald-50 px-3 py-2 text-xs font-semibold text-emerald-700 transition-colors hover:bg-emerald-100 dark:border-emerald-800/80 dark:bg-emerald-950/40 dark:text-emerald-300 dark:hover:bg-emerald-900/40">
                    Get on Play Store
                </a>
            }
            @if (Tool.HasAppStoreUrl)
            {
                <a href="@Tool.AppStoreUrl" target="_blank" rel="noopener noreferrer" @onclick:stopPropagation="true"
                   class="inline-flex items-center rounded-xl border border-sky-200 bg-sky-50 px-3 py-2 text-xs font-semibold text-sky-700 transition-colors hover:bg-sky-100 dark:border-sky-800/80 dark:bg-sky-950/40 dark:text-sky-300 dark:hover:bg-sky-900/40">
                    Download on App Store
                </a>
            }
        </div>
    }
</div>

@code {
    [Parameter, EditorRequired] public AIWebsiteDto Tool { get; set; } = null!;

    private string _logoUrl = string.Empty;
    private int _logoFallbackStep;

    protected override void OnParametersSet()
    {
        _logoUrl = Tool.PrimaryLogoURL;
        _logoFallbackStep = 0;
    }

    private void OpenDetails() => Nav.NavigateTo($"/tools/{Tool.Id}");

    private void HandleLogoError()
    {
        if (_logoFallbackStep == 0 && !string.IsNullOrWhiteSpace(Tool.OfficialIconURL) && _logoUrl != Tool.OfficialIconURL)
        {
            _logoUrl = Tool.OfficialIconURL;
            _logoFallbackStep = 1;
            return;
        }

        if (_logoFallbackStep <= 1 && !string.IsNullOrWhiteSpace(Tool.ReliablePublicIconURL) && _logoUrl != Tool.ReliablePublicIconURL)
        {
            _logoUrl = Tool.ReliablePublicIconURL;
            _logoFallbackStep = 2;
            return;
        }

        _logoUrl = string.Empty;
    }
}
