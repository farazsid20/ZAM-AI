@page "/admin"
@using ZamAiMart.Client.Models
@using ZamAiMart.Client.Services
@inject ApiService Api

<PageTitle>Admin - ZAM AI MART</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-8">
        <h1 class="text-3xl font-black text-gray-900 dark:text-white">Admin Panel</h1>
        <p class="mt-2 text-gray-500 dark:text-gray-400">Add and edit AI tools, including optional Play Store and App Store links.</p>
    </div>

    <div class="grid gap-8 xl:grid-cols-[1.1fr_0.9fr]">
        <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="mb-6 flex items-center justify-between gap-3">
                <div>
                    <h2 class="text-xl font-black text-gray-900 dark:text-white">@(_editingId.HasValue ? "Edit AI Tool" : "Add AI Tool")</h2>
                    <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Website is required. Mobile app links are optional and validated.</p>
                </div>
                @if (_editingId.HasValue)
                {
                    <button @onclick="ResetForm" class="rounded-xl border border-gray-200 px-4 py-2 text-sm font-medium text-gray-600 transition-colors hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700">
                        New Tool
                    </button>
                }
            </div>

            <EditForm Model="_form" OnValidSubmit="SaveAsync">
                <DataAnnotationsValidator />
                <ValidationSummary class="mb-4 rounded-2xl border border-rose-200 bg-rose-50 px-4 py-3 text-sm text-rose-700 dark:border-rose-900/40 dark:bg-rose-950/30 dark:text-rose-300" />

                <div class="grid gap-5 md:grid-cols-2">
                    <div class="md:col-span-2">
                        <label class="mb-2 block text-sm font-semibold text-gray-800 dark:text-gray-200">Tool Name</label>
                        <InputText @bind-Value="_form.Name" class="@InputClass" />
                        <ValidationMessage For="@(() => _form.Name)" class="@ValidationClass" />
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-semibold text-gray-800 dark:text-gray-200">Category</label>
                        <InputText @bind-Value="_form.Category" class="@InputClass" />
                        <ValidationMessage For="@(() => _form.Category)" class="@ValidationClass" />
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-semibold text-gray-800 dark:text-gray-200">Price (INR)</label>
                        <InputNumber @bind-Value="_form.PriceINR" class="@InputClass" />
                        <ValidationMessage For="@(() => _form.PriceINR)" class="@ValidationClass" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="inline-flex items-center gap-3 rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm font-medium text-gray-700 dark:border-gray-700 dark:bg-gray-900/40 dark:text-gray-300">
                            <InputCheckbox @bind-Value="_form.IsFree" />
                            Mark this tool as free
                        </label>
                    </div>

                    <div class="md:col-span-2">
                        <label class="mb-2 block text-sm font-semibold text-gray-800 dark:text-gray-200">Website URL</label>
                        <InputText @bind-Value="_form.WebsiteURL" class="@InputClass" />
                        <ValidationMessage For="@(() => _form.WebsiteURL)" class="@ValidationClass" />
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-semibold text-gray-800 dark:text-gray-200">Play Store URL</label>
                        <InputText @bind-Value="_form.PlayStoreUrl" class="@InputClass" />
                        <ValidationMessage For="@(() => _form.PlayStoreUrl)" class="@ValidationClass" />
                    </div>

                    <div>
                        <label class="mb-2 block text-sm font-semibold text-gray-800 dark:text-gray-200">App Store URL</label>
                        <InputText @bind-Value="_form.AppStoreUrl" class="@InputClass" />
                        <ValidationMessage For="@(() => _form.AppStoreUrl)" class="@ValidationClass" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="mb-2 block text-sm font-semibold text-gray-800 dark:text-gray-200">Logo URL</label>
                        <InputText @bind-Value="_form.LogoURL" class="@InputClass" />
                        <ValidationMessage For="@(() => _form.LogoURL)" class="@ValidationClass" />
                    </div>

                    <div class="md:col-span-2">
                        <label class="mb-2 block text-sm font-semibold text-gray-800 dark:text-gray-200">Description</label>
                        <InputTextArea @bind-Value="_form.Description" class="@($"{InputClass} min-h-28")" />
                        <ValidationMessage For="@(() => _form.Description)" class="@ValidationClass" />
                    </div>
                </div>

                <div class="mt-6 flex flex-wrap gap-3">
                    <button type="submit" class="rounded-2xl bg-violet-600 px-5 py-3 text-sm font-semibold text-white transition-colors hover:bg-violet-700">
                        @(_editingId.HasValue ? "Update Tool" : "Add Tool")
                    </button>
                    <button type="button" @onclick="ResetForm" class="rounded-2xl border border-gray-200 px-5 py-3 text-sm font-semibold text-gray-600 transition-colors hover:bg-gray-50 dark:border-gray-700 dark:text-gray-300 dark:hover:bg-gray-700">
                        Reset
                    </button>
                </div>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(_statusMessage))
            {
                <div class="mt-5 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm font-medium text-emerald-700 dark:border-emerald-900/40 dark:bg-emerald-950/30 dark:text-emerald-300">
                    @_statusMessage
                </div>
            }
        </section>

        <section class="rounded-[2rem] border border-gray-200 bg-white p-6 shadow-sm dark:border-gray-700 dark:bg-gray-800">
            <div class="mb-5">
                <h2 class="text-xl font-black text-gray-900 dark:text-white">Current Tools</h2>
                <p class="mt-1 text-sm text-gray-500 dark:text-gray-400">Select any tool to edit its website and mobile app links.</p>
            </div>

            @if (_loading)
            {
                <LoadingSpinner Message="Loading tools..." />
            }
            else
            {
                <div class="space-y-3 max-h-[70vh] overflow-y-auto pr-1">
                    @foreach (var tool in _tools)
                    {
                        <button @onclick="@(() => StartEdit(tool))"
                                class="w-full rounded-2xl border px-4 py-4 text-left transition-all @(tool.Id == _editingId ? "border-violet-300 bg-violet-50 dark:border-violet-700 dark:bg-violet-900/20" : "border-gray-200 bg-gray-50 hover:border-violet-200 hover:bg-white dark:border-gray-700 dark:bg-gray-900/40 dark:hover:bg-gray-800")">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <div class="font-semibold text-gray-900 dark:text-white">@tool.Name</div>
                                    <div class="mt-1 text-sm text-gray-500 dark:text-gray-400">@tool.Category</div>
                                </div>
                                <div class="text-xs font-semibold @(tool.HasMobileApps ? "text-emerald-600 dark:text-emerald-400" : "text-gray-400 dark:text-gray-500")">
                                    @(tool.HasMobileApps ? "Mobile links added" : "Website only")
                                </div>
                            </div>
                            <div class="mt-3 flex flex-wrap gap-2 text-xs">
                                @if (tool.HasPlayStoreUrl)
                                {
                                    <span class="rounded-full bg-emerald-100 px-2.5 py-1 font-semibold text-emerald-700 dark:bg-emerald-950/40 dark:text-emerald-300">Play Store</span>
                                }
                                @if (tool.HasAppStoreUrl)
                                {
                                    <span class="rounded-full bg-sky-100 px-2.5 py-1 font-semibold text-sky-700 dark:bg-sky-950/40 dark:text-sky-300">App Store</span>
                                }
                            </div>
                        </button>
                    }
                </div>
            }
        </section>
    </div>
</div>

@code {
    private const string InputClass = "w-full rounded-2xl border border-gray-200 bg-gray-50 px-4 py-3 text-sm text-gray-900 shadow-sm outline-none transition focus:border-violet-300 focus:bg-white focus:ring-2 focus:ring-violet-200 dark:border-gray-700 dark:bg-gray-900/40 dark:text-white dark:focus:border-violet-600 dark:focus:bg-gray-900 dark:focus:ring-violet-900/40";
    private const string ValidationClass = "mt-2 block text-sm text-rose-600 dark:text-rose-400";

    private List<AIWebsiteDto> _tools = new();
    private CreateAIWebsiteDto _form = new();
    private int? _editingId;
    private bool _loading = true;
    private string? _statusMessage;

    protected override async Task OnInitializedAsync()
    {
        await ReloadToolsAsync();
    }

    private async Task ReloadToolsAsync()
    {
        _loading = true;
        _tools = await Api.GetAllWebsitesAsync();
        _loading = false;
    }

    private void StartEdit(AIWebsiteDto tool)
    {
        _editingId = tool.Id;
        _form = CreateAIWebsiteDto.FromDto(tool);
        _statusMessage = null;
    }

    private void ResetForm()
    {
        _editingId = null;
        _form = new CreateAIWebsiteDto();
        _statusMessage = null;
    }

    private async Task SaveAsync()
    {
        var savedId = await Api.SaveWebsiteAsync(_editingId, _form);
        await ReloadToolsAsync();

        var savedTool = _tools.FirstOrDefault(t => t.Id == savedId);

        _editingId = savedTool?.Id;
        _statusMessage = _editingId.HasValue
            ? "Tool saved successfully. Website and mobile app links are now live in the UI."
            : "Tool saved successfully.";

        if (_editingId.HasValue && savedTool is not null)
        {
            _form = CreateAIWebsiteDto.FromDto(savedTool);
        }
    }
}
